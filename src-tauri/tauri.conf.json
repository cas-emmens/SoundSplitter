{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SoundSplitter",
  "version": "0.2.0",
  "identifier": "nl.emmens.soundsplitter",
  "build": {
    "frontendDist": "splash"
  },
  "app": {
    "windows": [
      {
        "title": "SoundSplitter",
        "width": 1280,
        "height": 840,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
