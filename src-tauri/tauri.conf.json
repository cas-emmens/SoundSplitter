{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sound Splitter",
  "version": "0.1.0",
  "identifier": "nl.emmens.soundsplitter",
  "build": {
    "frontendDist": "splash"
  },
  "app": {
    "windows": [
      {
        "title": "Sound Splitter",
        "width": 1280,
        "height": 840,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
